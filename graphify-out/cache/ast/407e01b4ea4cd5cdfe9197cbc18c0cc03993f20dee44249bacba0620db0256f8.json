{textClass} ${disabled ? 'text-gray-300 line-through cursor-not-allowed' : 'cursor-pointer'\n                }`}\n            >\n              {dayNumber}\n            </button>\n          );\n        })}\n      </div>\n    </div>\n  );\n\n  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December']", "is_member_call": false, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L386"}, {"caller_nid": "id_page_rendermonth", "callee": "getMonth", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L432"}, {"caller_nid": "id_page_rendermonth", "callee": "getFullYear", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L432"}, {"caller_nid": "id_page_rendermonth", "callee": "getMonth", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L433"}, {"caller_nid": "id_page_rendermonth", "callee": "substring", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L518"}, {"caller_nid": "id_page_rendermonth", "callee": "length", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L518"}, {"caller_nid": "id_page_rendermonth", "callee": "slug", "is_member_call": true, "source_file": "C:\\Users\\saisr\\Desktop\\Kunnath\\client\\app\\stays\\[id]\\page.tsx", "source_location": "L518"}]}